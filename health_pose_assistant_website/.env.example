POSTGRES_DB=health_pose_assistant
POSTGRES_USER=hpa_user
POSTGRES_PASSWORD=set-a-local-dev-password
BACKEND_DATABASE_URL=postgresql://hpa_user:set-a-local-dev-password@db:5432/health_pose_assistant
